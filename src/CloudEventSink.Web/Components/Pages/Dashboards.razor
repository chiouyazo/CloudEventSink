@page "/dashboards"
@attribute [Authorize]
@using System.Security.Claims
@using CloudEventSink.Core.Entities
@inject IDashboardRepository DashboardsRepo
@inject IUnitOfWork UnitOfWork
@inject IClock Clock
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Dashboards</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">Dashboards</MudText>
    <div class="d-flex gap-2 align-center">
        <MudTextField @bind-Value="newName" Label="New dashboard" Margin="Margin.Dense" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="CreateAsync">Create</MudButton>
    </div>
</div>

@if (dashboards is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (dashboards.Count == 0)
{
    <MudAlert Severity="Severity.Info">No dashboards yet.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (Dashboard dashboard in dashboards)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Outlined="true">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@dashboard.Name</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">@dashboard.Description</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Size="Size.Small" Color="Color.Primary" OnClick="() => Open(dashboard.Id)">Open</MudButton>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(dashboard)" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<Dashboard>? dashboards;
    private string newName = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        IReadOnlyList<Dashboard> loaded = await DashboardsRepo.ListAsync(CancellationToken.None);
        dashboards = new List<Dashboard>(loaded);
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(newName))
        {
            return;
        }

        DateTimeOffset now = Clock.UtcNow;
        Dashboard dashboard = new Dashboard
        {
            Id = Guid.NewGuid(),
            Name = newName.Trim(),
            CreatedBy = await CurrentUserIdAsync(),
            CreatedAtUtc = now,
            UpdatedAtUtc = now,
        };
        DashboardsRepo.Add(dashboard);
        await UnitOfWork.SaveChangesAsync(CancellationToken.None);
        newName = string.Empty;
        Navigation.NavigateTo($"/dashboards/{dashboard.Id}");
    }

    private async Task DeleteAsync(Dashboard dashboard)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete dashboard",
            $"Delete '{dashboard.Name}' and its panels?",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        Dashboard? tracked = await DashboardsRepo.GetByIdAsync(dashboard.Id, CancellationToken.None);
        if (tracked is not null)
        {
            DashboardsRepo.Remove(tracked);
            await UnitOfWork.SaveChangesAsync(CancellationToken.None);
        }

        await ReloadAsync();
    }

    private void Open(Guid id)
    {
        Navigation.NavigateTo($"/dashboards/{id}");
    }

    private async Task<string> CurrentUserIdAsync()
    {
        if (AuthState is null)
        {
            return "unknown";
        }

        AuthenticationState state = await AuthState;
        return state.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? state.User.Identity?.Name
            ?? "unknown";
    }
}
