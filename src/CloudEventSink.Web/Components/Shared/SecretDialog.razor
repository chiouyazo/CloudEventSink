@inject IJSRuntime Js
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            The secret is shown only once. Copy it now. It cannot be retrieved again.
        </MudAlert>

        <MudTextField T="string"
                      Value="IngestUrl"
                      ReadOnly="true"
                      Label="Ingest URL"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="@(() => CopyAsync(IngestUrl, "Ingest URL"))" />

        <MudTextField T="string"
                      Value="Secret"
                      ReadOnly="true"
                      Label="@SecretLabel"
                      Variant="Variant.Outlined"
                      Class="mb-3"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="@(() => CopyAsync(Secret, "Secret"))" />

        <MudText Typo="Typo.subtitle2" Class="mb-1">Example request</MudText>
        <MudTextField T="string"
                      Value="ExampleCommand"
                      ReadOnly="true"
                      Variant="Variant.Outlined"
                      Lines="9"
                      Class="ces-code"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="@(() => CopyAsync(ExampleCommand, "Command"))" />
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">Done</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Secret { get; set; } = string.Empty;

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [Parameter]
    public SourceAuthMode AuthMode { get; set; }

    private string sampleId = string.Empty;

    private string IngestUrl => $"{Navigation.BaseUri}ingest/{Slug}";

    private string SecretLabel => AuthMode == SourceAuthMode.Bearer ? "Bearer token (secret)" : "HMAC signing secret";

    private string SamplePayload =>
        $"{{\"specversion\":\"1.0\",\"id\":\"{sampleId}\",\"type\":\"com.example.event\",\"source\":\"my-app\",\"datacontenttype\":\"application/json\",\"data\":{{\"hello\":\"world\"}}}}";

    private string ExampleCommand => AuthMode == SourceAuthMode.Bearer ? BearerCommand() : HmacCommand();

    protected override void OnInitialized()
    {
        sampleId = Guid.NewGuid().ToString();
    }

    private string BearerCommand()
    {
        return $"curl -X POST {IngestUrl} \\\n"
            + $"  -H \"Authorization: Bearer {Secret}\" \\\n"
            + "  -H \"Content-Type: application/cloudevents+json\" \\\n"
            + $"  -d '{SamplePayload}'";
    }

    private string HmacCommand()
    {
        return $"BODY='{SamplePayload}'\n"
            + $"SIG=$(printf '%s' \"$BODY\" | openssl dgst -sha256 -hmac \"{Secret}\" | sed 's/^.*= //')\n"
            + $"curl -X POST {IngestUrl} \\\n"
            + "  -H \"X-Signature: sha256=$SIG\" \\\n"
            + "  -H \"Content-Type: application/cloudevents+json\" \\\n"
            + "  -d \"$BODY\"";
    }

    private async Task CopyAsync(string value, string what)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", value);
        Snackbar.Add($"{what} copied to clipboard.", Severity.Success);
    }

    private void Close()
    {
        MudDialog.Close();
    }
}
