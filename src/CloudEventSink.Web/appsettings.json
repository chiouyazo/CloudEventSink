{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Admin": {
    "Email": "",
    "Password": ""
  },
  "RateLimit": {
    "IngestPerMinute": 100
  },
  "Ingest": {
    "MaxBodyBytes": 1048576
  },
  "AllowedHosts": "*"
}
